generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
}

enum EntryType {
  ASSET
  LIABILITY
}

enum PassiveIncomeType {
  BOND_INTEREST
  SB_INTEREST
  DIVIDEND
  PROFIT
  OTHER
}

enum AssetType {
  PPF
  STOCKS
  BONDS
  US_STOCKS
  FIXED_DEPOSIT
  MUTUAL_FUNDS
  SMALLCASE
  LIC
  GOLD
  CRYPTO
  PROPERTY
  OTHER
}

enum LoanType {
  HOME
  PERSONAL
  CAR
  EDUCATION
  GOLD
  OTHER
}

enum LoanRole {
  OWNER
  MEMBER
}

enum LoanPaymentType {
  BOOKING
  DOWN_PAYMENT
  INSTALLMENT
  TDS
  AGREEMENT
  FEE
  OTHER
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(MEMBER)
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  monthlyHeaders MonthlyHeader[]
  transactions   Transaction[]
  categories     Category[]
  emis           EMI[]
  annualEntries  AnnualEntry[]
  passiveIncomes PassiveIncome[]
  assets         Asset[]
  budgetTargets  BudgetTarget[]
  monthlyBills   MonthlyBill[]
  billPayments   MonthlyBillPayment[]

  createdLoans    Loan[]        @relation("LoanCreator")
  loanMemberships LoanMember[]  @relation("LoanMembership")
  loanPayments    LoanPayment[] @relation("LoanPaymentPayer")
  emiEntries      EmiEntry[]    @relation("EmiEntryMember")

  @@map("users")
}

model MonthlyHeader {
  id        String   @id @default(uuid())
  userId    String
  year      Int
  month     Int
  income    Decimal  @db.Decimal(12, 2)
  emiTotal  Decimal  @db.Decimal(12, 2)
  savings   Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, year, month])
  @@map("monthly_headers")
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  monthlyHeaderId String?
  date            DateTime @db.Date
  categoryId      String
  subcategory     String?
  description     String
  amount          Decimal  @db.Decimal(12, 2)
  isBulk          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyHeader MonthlyHeader? @relation(fields: [monthlyHeaderId], references: [id], onDelete: SetNull)
  category      Category       @relation(fields: [categoryId], references: [id])

  @@map("transactions")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String?
  color     String?
  sortOrder Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  budgetTargets      BudgetTarget[]
  monthlyBillRules   MonthlyBill[]

  @@map("categories")
}

model EMI {
  id        String    @id @default(uuid())
  userId    String
  name      String
  amount    Decimal   @db.Decimal(12, 2)
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emis")
}

model AnnualEntry {
  id          String    @id @default(uuid())
  userId      String
  year        Int
  entryType   EntryType
  category    String
  particulars String
  amount      Decimal   @db.Decimal(12, 2)
  entryDate   DateTime? @db.Date
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("annual_entries")
}

model PassiveIncome {
  id           String            @id @default(uuid())
  userId       String
  year         Int
  month        Int?
  sourceType   PassiveIncomeType
  sourceName   String
  amount       Decimal           @db.Decimal(12, 2)
  receivedDate DateTime?         @db.Date
  notes        String?
  createdAt    DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passive_incomes")
}

model Asset {
  id             String    @id @default(uuid())
  userId         String
  recordedDate   DateTime  @db.Date
  assetType      AssetType
  assetName      String
  currentValue   Decimal   @db.Decimal(14, 2)
  investedAmount Decimal?  @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assets")
}

model BudgetTarget {
  id           String   @id @default(uuid())
  userId       String
  categoryId   String
  year         Int
  month        Int?
  targetAmount Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("budget_targets")
}

model MonthlyBill {
  id              String   @id @default(uuid())
  userId          String
  name            String
  amount          Decimal? @db.Decimal(12, 2)
  dueDay          Int?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  matchCategoryId String?
  matchKeyword    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchCategory Category?            @relation(fields: [matchCategoryId], references: [id], onDelete: SetNull)
  payments      MonthlyBillPayment[]

  @@map("monthly_bills")
}

model MonthlyBillPayment {
  id            String    @id @default(uuid())
  userId        String
  monthlyBillId String
  year          Int
  month         Int
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  autoChecked   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyBill MonthlyBill @relation(fields: [monthlyBillId], references: [id], onDelete: Cascade)

  @@unique([userId, monthlyBillId, year, month])
  @@map("monthly_bill_payments")
}

// ─── Loan Tracker (Artha's first shared resource) ───────────────────────────────

model Loan {
  id               String    @id @default(uuid())
  name             String
  lender           String?
  loanType         LoanType  @default(HOME)
  sanctionedAmount Decimal?  @db.Decimal(14, 2)
  interestRate     Decimal?  @db.Decimal(5, 2)
  tenureMonths     Int?
  plannedEmiAmount Decimal?  @db.Decimal(12, 2)
  startDate        DateTime? @db.Date
  notes            String?
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy     User               @relation("LoanCreator", fields: [createdById], references: [id])
  members       LoanMember[]
  payments      LoanPayment[]
  emiEntries    EmiEntry[]
  disbursements LoanDisbursement[]

  @@map("loans")
}

model LoanMember {
  id       String   @id @default(uuid())
  loanId   String
  userId   String
  role     LoanRole @default(MEMBER)
  joinedAt DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user User @relation("LoanMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([loanId, userId])
  @@map("loan_members")
}

model LoanPayment {
  id          String          @id @default(uuid())
  loanId      String
  paidById    String
  date        DateTime        @db.Date
  type        LoanPaymentType @default(OTHER)
  description String
  amount      Decimal         @db.Decimal(14, 2)
  mode        String?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  loan   Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paidBy User @relation("LoanPaymentPayer", fields: [paidById], references: [id])

  @@map("loan_payments")
}

model EmiEntry {
  id           String    @id @default(uuid())
  loanId       String
  userId       String
  year         Int
  month        Int
  plannedShare Decimal   @default(0) @db.Decimal(12, 2)
  actualPaid   Decimal?  @db.Decimal(12, 2)
  mode         String?
  paidDate     DateTime? @db.Date
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user User @relation("EmiEntryMember", fields: [userId], references: [id])

  @@unique([loanId, userId, year, month])
  @@map("emi_entries")
}

model LoanDisbursement {
  id        String   @id @default(uuid())
  loanId    String
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_disbursements")
}
