generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
}

enum EntryType {
  ASSET
  LIABILITY
}

enum PassiveIncomeType {
  BOND_INTEREST
  SB_INTEREST
  DIVIDEND
  PROFIT
  OTHER
}

enum AssetType {
  PPF
  STOCKS
  BONDS
  US_STOCKS
  MUTUAL_FUNDS
  SMALLCASE
  LIC
  GOLD
  CRYPTO
  PROPERTY
  OTHER
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(MEMBER)
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  monthlyHeaders MonthlyHeader[]
  transactions   Transaction[]
  categories     Category[]
  emis           EMI[]
  annualEntries  AnnualEntry[]
  passiveIncomes PassiveIncome[]
  assets         Asset[]
  budgetTargets  BudgetTarget[]

  @@map("users")
}

model MonthlyHeader {
  id        String   @id @default(uuid())
  userId    String
  year      Int
  month     Int
  income    Decimal  @db.Decimal(12, 2)
  emiTotal  Decimal  @db.Decimal(12, 2)
  savings   Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, year, month])
  @@map("monthly_headers")
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String
  monthlyHeaderId String?
  date            DateTime @db.Date
  categoryId      String
  subcategory     String?
  description     String
  amount          Decimal  @db.Decimal(12, 2)
  isBulk          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyHeader MonthlyHeader? @relation(fields: [monthlyHeaderId], references: [id], onDelete: SetNull)
  category      Category       @relation(fields: [categoryId], references: [id])

  @@map("transactions")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String?
  color     String?
  sortOrder Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgetTargets BudgetTarget[]

  @@map("categories")
}

model EMI {
  id        String    @id @default(uuid())
  userId    String
  name      String
  amount    Decimal   @db.Decimal(12, 2)
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emis")
}

model AnnualEntry {
  id          String    @id @default(uuid())
  userId      String
  year        Int
  entryType   EntryType
  category    String
  particulars String
  amount      Decimal   @db.Decimal(12, 2)
  entryDate   DateTime? @db.Date
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("annual_entries")
}

model PassiveIncome {
  id           String            @id @default(uuid())
  userId       String
  year         Int
  month        Int?
  sourceType   PassiveIncomeType
  sourceName   String
  amount       Decimal           @db.Decimal(12, 2)
  receivedDate DateTime?         @db.Date
  notes        String?
  createdAt    DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passive_incomes")
}

model Asset {
  id             String    @id @default(uuid())
  userId         String
  recordedDate   DateTime  @db.Date
  assetType      AssetType
  assetName      String
  currentValue   Decimal   @db.Decimal(14, 2)
  investedAmount Decimal?  @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assets")
}

model BudgetTarget {
  id           String   @id @default(uuid())
  userId       String
  categoryId   String
  year         Int
  month        Int?
  targetAmount Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@map("budget_targets")
}
